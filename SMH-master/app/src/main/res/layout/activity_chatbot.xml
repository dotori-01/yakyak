<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ChatbotActivity">


    <!-- 추가: 상담봇 상단바 -->

    <!-- 추가: 채팅 본문 -->
    <RelativeLayout
        android:id="@+id/chatbot_top_bar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="0dp"
        android:background="@color/white"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btn_back_chatbot"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:background="@android:color/transparent"
            android:contentDescription="뒤로가기"
            android:src="@drawable/ic_arrow_left" />

        <TextView
            android:id="@+id/tv_chatbot_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="상담봇"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:id="@+id/chat_scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingStart="14dp"
        android:paddingTop="8dp"
        android:paddingEnd="14dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/chatbot_top_bar"
        app:layout_constraintBottom_toTopOf="@id/chat_input_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 추가: 상담봇 헤더 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_chatbot"
                    android:contentDescription="상담봇 아이콘" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="상담봇"
                    android:textColor="@color/black"
                    android:textSize="22sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 추가: 첫 안내 말풍선 -->
            <LinearLayout
                android:layout_width="301dp"
                android:layout_height="64dp"
                android:layout_marginStart="4dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_chat_bubble_left"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingTop="10dp"
                android:paddingEnd="14dp"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="228dp"
                    android:layout_height="wrap_content"
                    android:gravity="start|center_vertical"
                    android:lineSpacingExtra="2dp"
                    android:text="안녕하세요! 24시간 언제든 복약 관련 질문에 답변해 드리는 AI 상담봇입니다."
                    android:textColor="@color/black"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- 자주 찾는 질문 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="240dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_chat_bubble_left"
                android:orientation="vertical"
                android:paddingStart="10dp"
                android:paddingTop="10dp"
                android:paddingEnd="10dp"
                android:paddingBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginBottom="8dp"
                    android:text="자주 찾는 질문"
                    android:textColor="@color/main_coral"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <!-- ⏰ 복용 시간 방법 -->
                <Button
                    android:id="@+id/btn_q_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_quick_question"
                    android:backgroundTint="@null"
                    android:gravity="center"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="10dp"
                    android:paddingTop="0dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="0dp"
                    android:text="⏰ 복용 시간 방법"
                    android:textAllCaps="false"
                    android:textColor="@color/black"
                    android:textSize="13sp"
                    app:backgroundTint="@null" />

                <Button
                    android:id="@+id/btn_q_side_effect"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_quick_question"
                    android:backgroundTint="@null"
                    android:gravity="center"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="10dp"
                    android:paddingTop="0dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="0dp"
                    android:text="⚠️ 부작용"
                    android:textAllCaps="false"
                    android:textColor="@color/black"
                    android:textSize="13sp"
                    app:backgroundTint="@null" />

                <Button
                    android:id="@+id/btn_q_interaction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_quick_question"
                    android:backgroundTint="@null"
                    android:gravity="center"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="10dp"
                    android:paddingTop="0dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="0dp"
                    android:text="🚫 병용 금지"
                    android:textAllCaps="false"
                    android:textColor="@color/black"
                    android:textSize="13sp"
                    app:backgroundTint="@null" />

                <Button
                    android:id="@+id/btn_q_scan_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_quick_question"
                    android:backgroundTint="@null"
                    android:gravity="center"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="10dp"
                    android:paddingTop="0dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="0dp"
                    android:text="💊 스캔한 약 상세 설명"
                    android:textAllCaps="false"
                    android:textColor="@color/black"
                    android:textSize="13sp"
                    app:backgroundTint="@null" />

                <Button
                    android:id="@+id/btn_q_guardian"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_quick_question"
                    android:backgroundTint="@null"
                    android:gravity="center"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:paddingStart="10dp"
                    android:paddingTop="0dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="0dp"
                    android:text="👤 보호자용 상태 요약 보기"
                    android:textAllCaps="false"
                    android:textColor="@color/black"
                    android:textSize="13sp"
                    app:backgroundTint="@null" />
            </LinearLayout>
            <!-- 추가: 사용자 질문 -->
            <LinearLayout
                android:id="@+id/layout_user_question"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="14dp"
                android:layout_marginStart="48dp"
                android:background="@drawable/bg_quick_question_selected"
                android:paddingStart="16dp"
                android:paddingTop="10dp"
                android:paddingEnd="16dp"
                android:paddingBottom="10dp">

                <TextView
                    android:id="@+id/tv_user_question"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="병용 금지"
                    android:textColor="@color/black"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- 추가: 챗봇 응답 -->
            <LinearLayout
                android:id="@+id/layout_chatbot_typing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_chat_bubble_left"
                android:paddingStart="18dp"
                android:paddingTop="10dp"
                android:paddingEnd="18dp"
                android:paddingBottom="10dp">

                <TextView
                    android:id="@+id/tv_chatbot_response"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="..."
                    android:textColor="@color/black"
                    android:textSize="15sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- 하단 입력창 -->
    <LinearLayout
        android:id="@+id/chat_input_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingTop="4dp"
        android:paddingEnd="10dp"
        android:paddingBottom="5dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_bg_chat"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/et_chat_input"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:background="@drawable/bg_chat_input"
            android:hint="궁금한 점을 입력하세요..."
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/black"
            android:textColorHint="@color/dark_gray"
            android:textSize="14sp" />

        <ImageButton
            android:id="@+id/btn_send_chat"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_send_button"
            android:contentDescription="전송"
            android:padding="8dp"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/ic_send"
            app:tint="@color/white" />
    </LinearLayout>

    <!-- 추가: 하단 네비 배경 -->
    <View
        android:id="@+id/bottom_bg_chat"
        android:layout_width="0dp"
        android:layout_height="74dp"
        android:background="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 추가: 하단 네비 -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav_chat"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="@id/bottom_bg_chat"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/bottom_bg_chat"
        app:layout_constraintVertical_bias="0.0"
        app:menu="@menu/nav_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>